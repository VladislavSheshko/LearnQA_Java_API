    Полный разбор ответа

Response response = RestAssured
    .given()
    .body(newOrder)
    .post("/api/orders")
    .andReturn();

// Проверка ВСЕГО:
assertEquals(201, response.getStatusCode());
assertEquals("application/json", response.getHeader("Content-Type"));
assertTrue(response.getCookie("session").length() > 0);
response.prettyPrint();

// Извлечение нескольких значений:
String orderId = response.path("id");
String status = response.path("status");
String customer = response.path("customer.name");

// Конвертация в POJO:
Order order = response.as(Order.class);