Можно проверять:

// Статус и статус-лайн
response.getStatusCode();           // 200
response.getStatusLine();           // "HTTP/1.1 200 OK"

// Headers
response.getHeader("Content-Type");
response.getHeaders();              // все headers

// Cookies
response.getCookies();
response.getCookie("session_id");

// Body (как строка)
response.getBody();                 // строка JSON
response.prettyPrint();             // красивый вывод в консоль [web:2]

// Извлечение через path
response.path("data.id");           // String
response.getBody().getPath("name"); // через JsonPath внутри

